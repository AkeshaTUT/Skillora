# Database
DB_USER=user
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_NAME=skillora_db
# Optional hard override
# SKILLORA_DATABASE_URL=postgresql://user:password@db:5432/skillora_db

# JWT / Security
SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=admin123
# Optional bcrypt hash for password (preferred in production)
# API_ADMIN_PASSWORD_HASH=$2b$12$...

# CORS
CORS_ORIGINS=*

# Cache
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=60

# Collector
SCHEDULER_INTERVAL_HOURS=6
# SCRAPER_PROXY=http://user:pass@host:port
